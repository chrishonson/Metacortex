{
  "name": "meta-cortex-functions",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"const fs=require('fs'); fs.rmSync('lib',{recursive:true,force:true}); fs.rmSync('coverage',{recursive:true,force:true});\"",
    "serve": "cd .. && firebase emulators:start --only functions,firestore",
    "shell": "firebase functions:shell",
    "smoke": "node scripts/mcp-smoke-test.mjs",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "express": "^5.1.0",
    "firebase-admin": "^13.7.0",
    "firebase-functions": "^7.2.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.5.2",
    "@vitest/coverage-v8": "^3.2.4",
    "supertest": "^7.1.4",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
